# ===== Server =====
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-here
ADMIN_API_KEY=your-admin-api-key-here

# ===== Database =====
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/mueblesar?schema=public

# ===== URLs (use your LAN IP for mobile AR testing) =====
SITE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# ===== Cloudinary (image/model CDN) =====
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ===== AI 3D Model Generation =====
MESHY_API_KEY=your-meshy-api-key
TRIPO_API_KEY=your-tripo-api-key

# ===== AWS S3 (3D model storage) =====
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=sa-east-1
AWS_BUCKET_NAME=your-bucket-name

# ===== Email (password reset) =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@amobly.com
